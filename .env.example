# Primary Provider Switch (gemini, openai, anthropic, or lmstudio)
LLM_PROVIDER=gemini

# Google Gemini API Key (required if using gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (required if using openai)
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic API Key (required if using anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-7-sonnet-20250219

# LM Studio Configuration
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=local-model
LM_STUDIO_EMBED_MODEL=nomic-embed-text-v1.5
